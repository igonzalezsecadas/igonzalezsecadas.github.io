---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Blog — Ignacio Gonzalez Secadas">
  <main>
    <section class="blog-index">
      <div class="blog-index-header">
        <h1>Blog</h1>
        <span>{String(posts.length).padStart(2, '0')}</span>
      </div>

      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="blog-row">
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </time>
          <div class="blog-row-body">
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
          </div>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="blog-row-tags">
              {post.data.tags.map((tag) => <span>{tag}</span>)}
            </div>
          )}
        </a>
      ))}
    </section>

    <Footer />
  </main>
</Layout>

<style>
  .blog-index {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    border-left: var(--border);
    border-right: var(--border);
    margin-top: 4rem;
  }

  .blog-index-header {
    padding: 2rem;
    border-bottom: var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .blog-index-header h1 {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-transform: lowercase;
    color: var(--fg);
  }

  .blog-index-header span {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    opacity: 0.4;
  }

  .blog-row {
    display: grid;
    grid-template-columns: 140px 1fr auto;
    gap: 2rem;
    padding: 2rem;
    border-bottom: var(--border);
    align-items: center;
    text-decoration: none;
    color: var(--fg);
    transition: background 0.2s, padding-left 0.3s;
    position: relative;
    overflow: hidden;
  }

  .blog-row:hover {
    background: var(--fg);
    color: var(--bg);
    padding-left: 2.5rem;
  }

  .blog-row time {
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    opacity: 0.4;
    text-transform: uppercase;
  }

  .blog-row-body h2 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    margin-bottom: 0.4rem;
    text-transform: none;
    transition: color 0.3s;
  }

  .blog-row:hover .blog-row-body h2 {
    color: var(--bg);
  }

  .blog-row:hover .blog-row-body p {
    color: var(--bg);
    opacity: 0.6;
  }

  .blog-row:hover time {
    color: var(--bg);
    opacity: 0.4;
  }

  .blog-row-body p {
    font-size: 0.9rem;
    opacity: 0.5;
    line-height: 1.5;
  }

  .blog-row-tags {
    display: flex;
    gap: 0.2rem 0.6rem;
    flex-wrap: wrap;
  }

  .blog-row-tags span {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    opacity: 0.5;
    transition: opacity 0.3s, color 0.3s;
  }

  .blog-row-tags span:not(:last-child)::after {
    content: '/';
    margin-left: 0.6rem;
    opacity: 0.3;
  }

  .blog-row:hover .blog-row-tags span {
    color: var(--bg);
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .blog-index {
      border-left: none;
      border-right: none;
      margin-top: 3rem;
    }

    .blog-row {
      grid-template-columns: 1fr;
      gap: 0.8rem;
    }

    .blog-row-tags {
      display: none;
    }
  }
</style>
