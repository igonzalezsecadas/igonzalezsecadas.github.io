<style>
  .projects {
    border-top: var(--border);
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    border-left: var(--border);
    border-right: var(--border);
  }

  /* ── Header ── */
  .projects-header {
    padding: 2rem;
    border-bottom: var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .projects-header h2 {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-transform: lowercase;
    color: var(--fg);
  }

  .projects-header h2::after {
    content: '';
    display: block;
    width: 48px;
    height: 3px;
    background: var(--accent);
    margin-top: 0.5rem;
  }

  .projects-header span {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    opacity: 0.4;
  }

  /* ── Cards ── */
  .project-card {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    gap: 2rem;
    padding: 2rem;
    border-bottom: var(--border);
    align-items: center;
    transition: background 0.2s, padding-left 0.3s;
    position: relative;
    overflow: hidden;
  }

  .project-card:last-child {
    border-bottom: none;
  }

  .project-card:hover {
    background: var(--fg);
    color: var(--bg);
    padding-left: 2.5rem;
  }

  .project-num {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--dim);
    line-height: 1;
    transition: color 0.3s;
  }

  .project-card:hover .project-num {
    color: var(--bg);
    opacity: 0.25;
  }

  /* ── Body (info + tags stacked) ── */
  .project-body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .project-info h3 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    margin-bottom: 0.3rem;
    text-transform: lowercase;
  }

  .project-card:hover .project-info h3 {
    color: var(--bg);
  }

  .project-info p {
    font-size: 0.8rem;
    opacity: 0.5;
    line-height: 1.5;
  }

  .project-card:hover .project-info p {
    color: var(--bg);
    opacity: 0.6;
  }

  /* ── Tags ── */
  .project-tags {
    display: flex;
    gap: 0.2rem 0.6rem;
    flex-wrap: wrap;
  }

  .project-tags span {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    opacity: 0.5;
    transition: opacity 0.3s, color 0.3s;
  }

  .project-tags span:not(:last-child)::after {
    content: '/';
    margin-left: 0.6rem;
    opacity: 0.3;
  }

  .project-card:hover .project-tags span {
    color: var(--bg);
    opacity: 0.7;
  }

  /* ── WIP badge ── */
  .project-tags .wip {
    color: var(--accent);
    opacity: 1;
  }

  .project-card:hover .project-tags .wip {
    color: var(--bg);
    opacity: 1;
  }

  /* ── GitHub link ── */
  .project-github {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: lowercase;
    text-decoration: none;
    color: var(--fg);
    padding: 0.5rem 1rem;
    border: 1px solid var(--fg);
    opacity: 0.7;
    transition: opacity 0.2s, color 0.3s, border-color 0.3s, background 0.2s;
  }

  .project-github:hover {
    opacity: 1;
    background: var(--fg);
    color: var(--bg);
  }

  .project-card:hover .project-github {
    color: var(--bg);
    border-color: var(--bg);
    opacity: 0.8;
  }

  .project-card:hover .project-github:hover {
    opacity: 1;
    background: var(--bg);
    color: var(--fg);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .projects {
      border-left: none;
      border-right: none;
    }

    .project-card {
      grid-template-columns: 50px 1fr auto;
    }

    .project-tags {
      display: none;
    }

    .project-github span {
      display: none;
    }

    .project-github {
      border: none;
      padding: 0.2rem;
    }

    .project-github:hover,
    .project-card:hover .project-github:hover {
      background: transparent;
    }
  }
</style>
