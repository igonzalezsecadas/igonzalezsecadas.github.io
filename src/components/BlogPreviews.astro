---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

if (posts.length === 0) return;
---

<section class="blog-previews" id="blog">
  <div class="blog-header reveal">
    <h3>Blog</h3>
    <span>{String(posts.length).padStart(2, '0')}</span>
  </div>

  <div class="blog-grid">
    {posts.map((post, i) => (
      <a href={`/blog/${post.id}`} class={`blog-card reveal reveal-delay-${i}`}>
        <div class="blog-card-meta">
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </time>
        </div>
        <div class="blog-card-body">
          <h4>{post.data.title}</h4>
          <p>{post.data.description}</p>
        </div>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="blog-card-tags">
            {post.data.tags.map((tag) => <span>{tag}</span>)}
          </div>
        )}
      </a>
    ))}
  </div>

  <div class="blog-footer reveal">
    <a href="/blog">View all posts →</a>
  </div>
</section>

<style>
  .blog-previews {
    border-top: var(--border);
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    border-left: var(--border);
    border-right: var(--border);
  }

  .blog-header {
    padding: 2rem;
    border-bottom: var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .blog-header h3 {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-transform: lowercase;
    color: var(--fg);
  }

  .blog-header span {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    opacity: 0.4;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
    border-right: var(--border);
    transition: background 0.2s;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    color: var(--fg);
  }

  .blog-card:last-child {
    border-right: none;
  }

  .blog-card:hover {
    background: var(--fg);
    color: var(--bg);
  }

  .blog-card-meta time {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    opacity: 0.4;
    text-transform: uppercase;
  }

  .blog-card-body h4 {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    margin-bottom: 0.4rem;
    text-transform: none;
    transition: color 0.3s;
  }

  .blog-card:hover .blog-card-body h4 {
    color: var(--bg);
  }

  .blog-card:hover .blog-card-body p {
    color: var(--bg);
    opacity: 0.6;
  }

  .blog-card:hover .blog-card-meta time {
    color: var(--bg);
    opacity: 0.4;
  }

  .blog-card-body p {
    font-size: 0.8rem;
    opacity: 0.5;
    line-height: 1.5;
  }

  .blog-card-tags {
    display: flex;
    gap: 0.2rem 0.6rem;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .blog-card-tags span {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    opacity: 0.5;
    transition: opacity 0.3s, color 0.3s;
  }

  .blog-card-tags span:not(:last-child)::after {
    content: '/';
    margin-left: 0.6rem;
    opacity: 0.3;
  }

  .blog-card:hover .blog-card-tags span {
    color: var(--bg);
    opacity: 0.7;
  }

  .blog-footer {
    padding: 1.5rem 2rem;
    border-top: var(--border);
    text-align: center;
  }

  .blog-footer a {
    color: var(--fg);
    text-decoration: none;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: lowercase;
    opacity: 0.5;
    transition: color 0.2s, opacity 0.2s;
  }

  .blog-footer a:hover {
    color: var(--accent);
    opacity: 1;
  }

  @media (max-width: 768px) {
    .blog-previews {
      border-left: none;
      border-right: none;
    }

    .blog-grid {
      grid-template-columns: 1fr;
    }

    .blog-card {
      border-right: none;
      border-bottom: var(--border);
    }

    .blog-card:last-child {
      border-bottom: none;
    }

    .blog-card-tags {
      display: none;
    }
  }
</style>
